<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ios_bg_base">

    <!-- 顶部状态栏 -->
    <LinearLayout
        android:id="@+id/navBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="48dp"
        android:paddingBottom="12dp"
        android:paddingHorizontal="20dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/ios_bg_elevated"
        app:layout_constraintTop_toTopOf="parent">
        
        <TextView
            android:id="@+id/topTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="天穹"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@color/ios_text_primary" />

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />
            
        <TextView
            android:id="@+id/connectionStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="未授权"
            android:textSize="13sp"
            android:layout_marginEnd="16dp"
            android:textColor="@color/ios_text_secondary" />

        <ImageView
            android:id="@+id/btnLogout"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_back"
            android:rotation="180"
            app:tint="@color/ios_red"
            android:visibility="gone" />
    </LinearLayout>

    <View
        android:id="@+id/navSeparator"
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="@color/ios_separator"
        app:layout_constraintTop_toBottomOf="@id/navBar" />

    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/nav_host_fragment"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/navSeparator"
        app:layout_constraintBottom_toTopOf="@id/bottomNav" />

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/ios_bg_elevated"
        app:elevation="0dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:menu="@menu/bottom_nav_menu"
        app:itemIconTint="@color/ios_blue"
        app:itemTextColor="@color/ios_text_secondary"
        app:labelVisibilityMode="labeled" />

    <!-- 极简授权页 (适应性设计) -->
    <LinearLayout
        android:id="@+id/setupOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/ios_bg_base"
        android:orientation="vertical"
        android:padding="40dp"
        android:elevation="100dp"
        android:visibility="visible">
        
        <ImageView
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:layout_marginTop="80dp"
            android:layout_gravity="center_horizontal"
            android:src="@mipmap/ic_launcher_round" />
            
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:layout_gravity="center_horizontal"
            android:text="访问授权"
            android:textSize="32sp"
            android:textStyle="bold"
            android:textColor="@color/ios_text_primary" />
        
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_gravity="center_horizontal"
            android:text="请输入安全访问密钥"
            android:textSize="15sp"
            android:textColor="@color/ios_text_secondary" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="48dp"
            android:background="@drawable/ios_card"
            android:orientation="vertical">
            
            <!-- 密钥输入框 (首要元素) -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:endIconMode="password_toggle"
                app:hintEnabled="false"
                app:boxBackgroundMode="none">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/adminPwdInput"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:background="@null"
                    android:hint="访问密钥 (Admin Key)"
                    android:inputType="textPassword"
                    android:paddingHorizontal="16dp"
                    android:textSize="17sp"
                    android:gravity="center" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- 服务器配置组 (默认隐藏，仅在无历史记录时或手动切换时显示) -->
            <LinearLayout
                android:id="@+id/serverConfigGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">
                
                <View android:layout_width="match_parent" android:layout_height="0.5dp" android:layout_marginStart="16dp" android:background="@color/ios_separator"/>

                <EditText
                    android:id="@+id/serverIpInput"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:background="@null"
                    android:hint="服务器 IP 地址"
                    android:paddingHorizontal="16dp"
                    android:textSize="16sp" />
                
                <View android:layout_width="match_parent" android:layout_height="0.5dp" android:layout_marginStart="16dp" android:background="@color/ios_separator"/>

                <EditText
                    android:id="@+id/serverPortInput"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:background="@null"
                    android:hint="管理端口 (默认 8080)"
                    android:inputType="number"
                    android:paddingHorizontal="16dp"
                    android:textSize="16sp" />
            </LinearLayout>
        </LinearLayout>

        <Button
            android:id="@+id/loginBtn"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="32dp"
            android:background="@drawable/apple_btn_bg"
            android:text="授权并进入"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/toggleServerConfig"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:layout_gravity="center_horizontal"
            android:text="更改服务器配置"
            android:textSize="14sp"
            android:textColor="@color/ios_blue" />

    </LinearLayout>

    <ProgressBar
        android:id="@+id/progressBar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:visibility="gone"
        android:progressTint="@color/ios_accent"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
