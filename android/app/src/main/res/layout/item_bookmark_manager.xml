<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:background="@drawable/ios_card"
    android:elevation="2dp"
    android:orientation="horizontal"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvBookmarkName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/ios_text_primary"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvBookmarkHost"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/ios_text_secondary"
            android:textSize="13sp" />
            
        <TextView
            android:id="@+id/tvBookmarkUser"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="@color/ios_text_secondary"
            android:textSize="13sp" />
    </LinearLayout>

    <!-- Edit Button -->
    <ImageView
        android:id="@+id/btnEditBookmark"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_gravity="center_vertical"
        android:layout_marginEnd="12dp"
        android:background="?android:attr/selectableItemBackgroundBorderless"
        android:padding="4dp"
        android:src="@drawable/ic_edit"
        android:contentDescription="编辑" />

    <!-- Delete Button -->
    <ImageView
        android:id="@+id/btnDeleteBookmark"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_gravity="center_vertical"
        android:background="?android:attr/selectableItemBackgroundBorderless"
        android:padding="4dp"
        android:src="@drawable/ic_delete"
        android:contentDescription="删除" />
</LinearLayout>
