<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@android:color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp">

        <CheckBox
            android:id="@+id/fileCheck"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:visibility="gone"
            android:layout_marginEnd="12dp"
            android:buttonTint="@color/ios_text_primary"/>

        <ImageView
            android:id="@+id/fileIcon"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:src="@drawable/ic_folder" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/fileName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/ios_text_primary"
                android:textSize="17sp"
                android:letterSpacing="-0.02"
                android:ellipsize="middle"
                android:singleLine="true"/>

            <TextView
                android:id="@+id/fileMeta"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/ios_text_secondary"
                android:textSize="12sp" />
        </LinearLayout>

        <ImageView
            android:id="@+id/btnMenu"
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:src="@drawable/ic_more"
            android:alpha="0.2"
            android:tint="@color/black" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:layout_marginStart="58dp"
        android:background="@color/ios_separator" />

</LinearLayout>
