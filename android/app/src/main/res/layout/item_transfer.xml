<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="@drawable/ios_card"
    android:layout_marginBottom="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">
        <TextView
            android:id="@+id/transferName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="FileName.txt"
            android:textColor="@color/ios_text_primary"
            android:textSize="14sp"
            android:textStyle="bold"
            android:ellipsize="middle"
            android:singleLine="true"/>
        <TextView
            android:id="@+id/transferStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="DOWNLOADING"
            android:textColor="@color/ios_accent"
            android:textSize="12sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/transferPath"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:textColor="@color/ios_text_secondary"
        android:textSize="11sp"
        android:ellipsize="middle"
        android:singleLine="true"/>

    <ProgressBar
        android:id="@+id/transferProgress"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="8dp"
        android:layout_marginTop="8dp"
        android:max="100"
        android:progress="0" />

</LinearLayout>
