<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical">
        <TextView
            android:id="@+id/diskMount"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="/root"
            android:textColor="@color/ios_text_primary"
            android:textSize="15sp" />
        <TextView
            android:id="@+id/diskUsageText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="45%"
            android:textColor="@color/ios_text_secondary"
            android:textSize="13sp" />
    </LinearLayout>

    <ProgressBar
        android:id="@+id/diskProgress"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="4dp"
        android:layout_marginTop="8dp"
        android:progress="45"
        android:progressTint="@color/ios_blue"
        android:progressBackgroundTint="@color/ios_separator" />
</LinearLayout>
